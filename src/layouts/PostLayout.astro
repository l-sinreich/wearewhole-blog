---
import BaseLayout from './BaseLayout.astro';
import type { Post } from '../lib/notion';

interface Props {
  post: Post;
  relatedPosts: Post[];
}

const { post, relatedPosts } = Astro.props;

/** "February 17, 2026" — full date for the post header */
function formatDate(dateStr: string): string {
  if (!dateStr) return '';
  const date = new Date(dateStr + 'T12:00:00');
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
}

/** "Feb 17, 2026" — abbreviated date for related post cards */
function formatCardDate(dateStr: string): string {
  if (!dateStr) return '';
  const date = new Date(dateStr + 'T12:00:00');
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  }).format(date);
}

/**
 * Convert Markdown (as produced by notion-to-md) to HTML.
 *
 * Notion block types handled:
 *   - Callout  → notion-to-md outputs as "> {emoji} {text}" (blockquote with emoji prefix)
 *               → rendered as <div class="callout"> (dark bg, white non-italic text)
 *   - Quote    → "> {text}" without emoji prefix
 *               → rendered as <blockquote> (white left bar, white non-italic text)
 *   - To-do    → "- [ ] {text}" / "- [x] {text}"
 *               → rendered as <li class="todo todo--unchecked/checked"> in <ul class="todo-list">
 *   - Headings → # ## ### #### → <h1>–<h4>
 *   - Lists    → ordered and unordered
 *   - Bold, italic, inline code, links, images, HR
 */
function markdownToHtml(md: string): string {
  if (!md) return '';
  return md
    // ── Fenced code blocks (process FIRST, before inline patterns) ──
    .replace(/```(\w*)\n([\s\S]*?)```/g, (_m, lang, code) => {
      const escaped = code.replace(/</g, '&lt;').replace(/>/g, '&gt;');
      return `<pre><code class="language-${lang || 'text'}">${escaped.trimEnd()}</code></pre>`;
    })
    // ── Headings ──
    .replace(/^#### (.+)$/gm, '<h4>$1</h4>')
    .replace(/^### (.+)$/gm,  '<h3>$1</h3>')
    .replace(/^## (.+)$/gm,   '<h2>$1</h2>')
    .replace(/^# (.+)$/gm,    '<h1>$1</h1>')
    // ── Horizontal rules ──
    .replace(/^---$/gm, '<hr>')
    // ── Inline formatting ──
    .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
    .replace(/\*\*(.+?)\*\*/g,     '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g,         '<em>$1</em>')
    .replace(/`([^`]+)`/g,         '<code>$1</code>')
    // ── Images ──
    .replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" loading="lazy">')
    // ── Links ──
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    // ── Callout — blockquote line whose first non-space char after "> " is an emoji.
    //    notion-to-md outputs callouts as "> {emoji} {text}".
    //    We match any line starting with "> " followed by a Unicode emoji character.
    //    The /u flag enables Unicode property escapes (\p{}).
    //    Callouts get a dark-bg box; quotes get a white left bar. ──
    .replace(/^> (\p{Emoji_Presentation}\S* .+)$/gmu, '<div class="callout"><p>$1</p></div>')
    // ── Standard blockquote (quote) — everything else starting with "> " ──
    .replace(/^> (.+)$/gm, '<blockquote><p>$1</p></blockquote>')
    // ── To-do items — detect BEFORE unordered list so "- [ ]" isn't eaten as a bullet ──
    .replace(/^- \[x\] (.+)$/gm, '<li class="todo todo--checked">$1</li>')
    .replace(/^- \[ \] (.+)$/gm, '<li class="todo todo--unchecked">$1</li>')
    // Wrap consecutive todo items in <ul class="todo-list">
    .replace(/(<li class="todo[^"]*">.*?<\/li>(\n<li class="todo[^"]*">.*?<\/li>)*)/gs,
      '<ul class="todo-list">$1</ul>')
    // ── Ordered lists — level 2 first (4-space indent), then level 1 ──
    // notion-to-md indents child items with 4 spaces per nesting level.
    // Process deeper levels before shallower so inner <ol>/<ul> are already
    // formed when the outer grouping regex runs.
    .replace(/^ {4}\d+\. (.+)$/gm, '<li class="ol2-item">$1</li>')
    .replace(/(<li class="ol2-item">.*?<\/li>(\n<li class="ol2-item">.*?<\/li>)*)/gs,
      '<ol class="nested">$1</ol>')
    .replace(/ class="ol2-item"/g, '')
    // Level 1 ordered — group consecutive <li> tags and any nested <ol>/<ul> that follow
    .replace(/^\d+\. (.+)$/gm, '<li class="ol-item">$1</li>')
    .replace(/(<li class="ol-item">.*?<\/li>(\n(?:<li class="ol-item">.*?<\/li>|<[uo]l[^>]*>[\s\S]*?<\/[uo]l>))*)/gs,
      '<ol>$1</ol>')
    .replace(/ class="ol-item"/g, '')
    // ── Unordered lists — level 2 first (4-space indent), then level 1 ──
    .replace(/^ {4}[-*] (.+)$/gm, '<li class="ul2-item">$1</li>')
    .replace(/(<li class="ul2-item">.*?<\/li>(\n<li class="ul2-item">.*?<\/li>)*)/gs,
      '<ul class="nested">$1</ul>')
    .replace(/ class="ul2-item"/g, '')
    // Level 1 unordered — group consecutive <li> tags and any nested <ol>/<ul> that follow
    .replace(/^[-*] (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*?<\/li>(\n(?:<li>.*?<\/li>|<[uo]l[^>]*>[\s\S]*?<\/[uo]l>))*)/gs, '<ul>$1</ul>')
    // ── Paragraphs — lines not already wrapped in a block tag ──
    // Exclusion list: h(eadings) u(l) p(re) b(lockquote via alias) o(l) c(ode) i(mg) l(i)
    // <li>, <ul>, <ol> all start with l/u/o — must be excluded or they get double-wrapped in <p>
    .replace(/^(?!<[hupolboci]|<blockquote|<pre|<hr|<div)(.+)$/gm, '<p>$1</p>')
    // ── Clean up ──
    .replace(/\n{3,}/g, '\n\n')
    .trim();
}

const formattedDate = formatDate(post.date);
const bodyHtml = markdownToHtml(post.body);
---

<BaseLayout title={post.title} description={post.excerpt || undefined}>
  <div class="container">

    <!-- ← See all posts (top) -->
    <a href="/blog/" class="post-back-link">&larr; See all posts</a>

    <!-- HERO IMAGE — shown before the title -->
    {post.coverImage && (
      <img
        class="post-hero"
        src={post.coverImage}
        alt={post.title}
        loading="eager"
      />
    )}

    <!-- POST HEADER: title, then date below -->
    <header class="post-header">
      <h1 class="post-header__title">{post.title}</h1>

      <div class="post-header__meta">
        {post.category && (
          <span class="post-header__category">{post.category}</span>
        )}
        {formattedDate && (
          <time class="post-header__date" datetime={post.date}>
            {formattedDate}
          </time>
        )}
      </div>
    </header>

    <!-- POST BODY -->
    <article class="post-body" set:html={bodyHtml} />

    <!-- TAG LIST -->
    {post.tags.length > 0 && (
      <aside class="post-tags">
        <p class="post-tags__label">Tags</p>
        <div class="tag-list">
          {post.tags.map((tag) => (
            <span class="tag-list__tag">{tag}</span>
          ))}
        </div>
      </aside>
    )}

    <!-- RELATED POSTS -->
    {relatedPosts.length > 0 && (
      <section class="related-posts">
        <h2 class="related-posts__heading">You might also be interested in these posts</h2>
        <div class="related-posts__grid">
          {relatedPosts.map((related) => (
            <a href={`/blog/${related.slug}/`} class="related-card">
              {related.coverImage ? (
                <img
                  class="related-card__image"
                  src={related.coverImage}
                  alt={related.title}
                  loading="lazy"
                />
              ) : (
                <div class="related-card__image-placeholder" aria-hidden="true">
                  <span>✦</span>
                </div>
              )}
              <div class="related-card__body">
                <p class="related-card__title">{related.title}</p>
                {related.date && (
                  <time class="related-card__date" datetime={related.date}>
                    {formatCardDate(related.date)}
                  </time>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- ← See all posts (bottom) -->
    <div class="post-back-bottom">
      <a href="/blog/" class="post-back-link">&larr; See all posts</a>
    </div>

  </div>
</BaseLayout>
