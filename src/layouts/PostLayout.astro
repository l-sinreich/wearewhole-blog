---
/**
 * src/layouts/PostLayout.astro
 *
 * The layout for individual blog posts.
 * Wraps BaseLayout and adds the post-specific structure:
 *   - Full-width hero image (if a cover image was set)
 *   - Post title, date, and category chip
 *   - Rendered Markdown body
 *   - Tag list at the bottom
 *
 * Props:
 *   post — a Post object from src/lib/notion.ts
 *
 * Why a separate layout instead of putting all this in [slug].astro?
 * Keeping layout logic in layouts/ separates structure from routing.
 * If you ever had a "featured post" with a different layout, you'd just
 * create a FeaturedPostLayout.astro — the routing file stays the same.
 */

import BaseLayout from './BaseLayout.astro';
import type { Post } from '../lib/notion';

interface Props {
  post: Post;
}

const { post } = Astro.props;

/**
 * Format a date string like "2026-02-17" → "February 17, 2026".
 *
 * Why not use the raw date string directly?
 * ISO dates (2026-02-17) are machine-readable but not reader-friendly.
 * The Intl.DateTimeFormat API is built into all modern browsers and Node —
 * no date library needed.
 *
 * Why new Date(post.date + 'T12:00:00')?
 * Parsing "2026-02-17" as a bare date in JavaScript gives you midnight UTC.
 * Depending on the reader's timezone, that could display as the day before.
 * Adding T12:00:00 (noon) avoids the off-by-one-day timezone issue.
 */
function formatDate(dateStr: string): string {
  if (!dateStr) return '';
  const date = new Date(dateStr + 'T12:00:00');
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
}

/**
 * Convert Markdown to HTML using a lightweight approach.
 *
 * notion-to-md already gives us well-structured Markdown. We render it
 * to HTML here using a simple regex-based approach for the common cases.
 *
 * For a production upgrade, you could use the 'marked' or 'remark' package
 * for full Markdown spec compliance — but for blog content generated by
 * notion-to-md, this covers everything Notion produces.
 */
function markdownToHtml(md: string): string {
  if (!md) return '';
  return md
    // Fenced code blocks — must be processed BEFORE inline code
    .replace(/```(\w*)\n([\s\S]*?)```/g, (_m, lang, code) => {
      const escaped = code.replace(/</g, '&lt;').replace(/>/g, '&gt;');
      return `<pre><code class="language-${lang || 'text'}">${escaped.trimEnd()}</code></pre>`;
    })
    // Headings
    .replace(/^#### (.+)$/gm, '<h4>$1</h4>')
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    // Horizontal rules
    .replace(/^---$/gm, '<hr>')
    // Bold and italic
    .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    // Inline code
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    // Images (Notion embeds images in Markdown)
    .replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" loading="lazy">')
    // Links
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>')
    // Blockquotes — must come before paragraph processing
    .replace(/^> (.+)$/gm, '<blockquote><p>$1</p></blockquote>')
    // Unordered lists — group consecutive list items
    .replace(/^[-*] (.+)$/gm, '<li>$1</li>')
    .replace(/(<li>[\s\S]*?<\/li>)(?!\n<li>)/g, '<ul>$1</ul>')
    // Ordered lists
    .replace(/^\d+\. (.+)$/gm, '<li>$1</li>')
    // Paragraphs — lines with content, not already wrapped in a block tag
    .replace(/^(?!<[hupboci]|<blockquote|<pre|<hr)(.+)$/gm, '<p>$1</p>')
    // Clean up empty lines and extra whitespace
    .replace(/\n{3,}/g, '\n\n')
    .trim();
}

const formattedDate = formatDate(post.date);
const bodyHtml = markdownToHtml(post.body);
---

<BaseLayout title={post.title} description={post.excerpt || undefined}>
  <!--
    HERO IMAGE
    Only rendered if the post has a cover image.
    The <img> is placed outside .container so it spans the full viewport width.

    Why loading="eager"? The hero image is above the fold — we want it to
    load immediately, not lazily. All other images in the body use lazy loading.
  -->
  {post.coverImage && (
    <img
      class="post-hero"
      src={post.coverImage}
      alt={post.title}
      loading="eager"
    />
  )}

  <div class="container">
    <!--
      POST HEADER: category chip, date, title
    -->
    <header class="post-header">
      <div class="post-header__meta">
        {post.category && (
          <!--
            Category chip — styled but not linked yet.
            To activate category pages later:
              Change this span to:
              <a href={`/blog/category/${post.category.toLowerCase().replace(/\s+/g, '-')}/`}
                 class="post-header__category">
          -->
          <span class="post-header__category">{post.category}</span>
        )}
        {formattedDate && (
          <time class="post-header__date" datetime={post.date}>
            {formattedDate}
          </time>
        )}
      </div>

      <h1 class="post-header__title">{post.title}</h1>
    </header>

    <!--
      POST BODY
      The Markdown content from Notion, converted to HTML.

      Why set:html instead of {bodyHtml}?
      Astro escapes HTML by default to prevent XSS. {bodyHtml} would render
      the HTML tags as literal text. set:html bypasses escaping — appropriate
      here because the source is our own Notion database, not user input.
    -->
    <article class="post-body" set:html={bodyHtml} />

    <!--
      TAG LIST
      Only rendered if the post has at least one tag.
      Tags are styled as chips but not linked yet.
      To activate tag pages later: change the <span> to an <a>.
    -->
    {post.tags.length > 0 && (
      <aside class="post-tags">
        <p class="post-tags__label">Tags</p>
        <div class="tag-list">
          {post.tags.map((tag) => (
            <!--
              Not linked yet — dormant until tag pages are surfaced.
              To activate: replace <span> with
              <a href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`}>
            -->
            <span class="tag-list__tag">{tag}</span>
          ))}
        </div>
      </aside>
    )}
  </div>
</BaseLayout>
