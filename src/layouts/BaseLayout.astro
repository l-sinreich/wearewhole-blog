---
/**
 * src/layouts/BaseLayout.astro
 *
 * The shared HTML shell for every page on the blog.
 * All pages import this layout and pass their content through <slot />.
 *
 * Why a shared layout?
 * The nav, footer, fonts, and <head> tags are the same on every page.
 * Defining them here means changing the nav once changes it everywhere.
 *
 * Props:
 *   title       — Page <title> tag and OG title. Should be unique per page.
 *   description — Meta description for SEO. Optional; falls back to a default.
 */

/**
 * Why import the CSS here instead of using a <link href="..."> tag?
 * Astro processes imports in the frontmatter and handles CSS correctly —
 * it bundles, hashes, and injects the stylesheet with optimal caching headers.
 * A plain <link href="/styles/global.css"> would require the file to be in
 * public/, which bypasses Astro's processing. Import = Astro manages it.
 */
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Signals & Sensemaking — Strategic design insights from WHOLE Innovation and Design.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Page title: appends site name unless this IS the home page -->
    <title>{title === 'Signals & Sensemaking' ? title : `${title} | Signals & Sensemaking`}</title>

    <!-- SEO meta tags -->
    <meta name="description" content={description} />

    <!--
      Favicon — reuse the one from the main site.
      Once deployed, update these paths to point to the actual wearewhole.co assets.
    -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!--
      Google Fonts — identical to the landing page link tag.
      We load both Archivo and Archivo Narrow in all weights used across the site.

      Why preconnect? It hints to the browser to establish a connection to
      Google's font servers early, reducing the font loading delay.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@100;300;400;700&family=Archivo+Narrow:wght@300;400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Global stylesheet is imported in the frontmatter above; Astro injects it here -->
  </head>

  <body>
    <!--
      NAVIGATION
      Logo (links back to wearewhole.co) on the left, back link on the right.
      No blog title in the nav — the page header carries the title instead.
    -->
    <nav class="blog-nav" aria-label="Blog navigation">
      <div class="nav-container">
        <a href="https://wearewhole.co" class="nav-logo" aria-label="WHOLE Innovation and Design">
          <img src="/images/logo.png" alt="WHOLE" />
        </a>
      </div>
    </nav>

    <!--
      MAIN CONTENT
      <slot /> is where each page's content is injected.
      The layout provides the wrapper; the page provides the content.
    -->
    <main>
      <slot />
    </main>

    <!--
      FOOTER
      Matches the landing page footer: dark background, yellow-tinted top border.
    -->
    <footer class="blog-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} WHOLE Innovation &amp; Design</p>
      </div>
    </footer>
  </body>
</html>
