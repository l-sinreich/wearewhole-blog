---
/**
 * src/layouts/WhitePaperLayout.astro
 *
 * The shell for the living white paper and its changelog. Deliberately its own
 * layout (not BaseLayout): the white paper is a LIGHT, quiet reading
 * environment, distinct from the dark marketing site and blog. It pulls in
 * whitepaper.css rather than global.css.
 *
 * Props:
 *   title       — <title> / OG title
 *   description — meta description
 */
import '../styles/whitepaper.css';

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'A living white paper from WHOLE Innovation & Design on organizational responsiveness in a moment of constant change.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WHOLE Innovation and Design | {title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/images/logo.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,300;0,400;0,500;0,700;1,400&family=Archivo+Narrow:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="wp-body">
    <nav class="wp-topnav" aria-label="Site">
      <a href="/" class="wp-topnav__logo" aria-label="WHOLE Innovation and Design — home">
        <img src="/images/logo.png" alt="WHOLE" />
      </a>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="wp-footer">
      <p>&copy; {new Date().getFullYear()} WHOLE Innovation &amp; Design</p>
    </footer>
  </body>
</html>
